{
  "name": "compliance-os",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Philippine BIR compliance tracking for CPAs and bookkeepers",
  "scripts": {
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",
    "test":      "vitest run",
    "test:watch":"vitest",
    "lint":      "eslint 'src/**/*.js' 'supabase/functions/**/*.ts'",
    "check":     "npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "eslint":                 "^9.18.0",
    "typescript-eslint":      "^8.20.0",
    "vite":                   "^6.0.7",
    "vitest":                 "^2.1.8"
  }
}
